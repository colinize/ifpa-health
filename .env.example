# IFPA Health — required environment variables.
# Copy to .env.local for local dev: `cp .env.example .env.local`
# Never commit real values. Values for the linked Vercel project live in
# the Vercel dashboard and are pulled via `vercel env pull .env.local`.

# Supabase project URL (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — browser-safe, RLS enforces read-only access
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS. Cron + admin + scripts only.
# NEVER expose to the client. Keep out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# IFPA v2 API key — used only by collectors and ops scripts (server-side).
IFPA_API_KEY=

# Shared bearer token for /api/cron/* routes.
CRON_SECRET=

# Shared bearer token for /api/admin/* routes.
# Split from CRON_SECRET so admin access can be revoked independently.
# If unset, admin routes fall back to CRON_SECRET (transitional).
ADMIN_SECRET=
